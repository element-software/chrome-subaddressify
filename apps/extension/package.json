{
  "name": "@subaddressify/extension",
  "version": "1.1.4",
  "private": true,
  "type": "module",
  "description": "Subaddressify - Email Aliases & Leak Detection",
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx --max-warnings 0",
    "clean": "rm -rf dist",
    "package": "pnpm build",
