  "dependencies": {
    "@subaddressify/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "@types/ws": "^8.18.1",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.4.5",
    "vite": "^5.2.11",
    "vite-plugin-static-copy": "^1.0.5",
    "ws": "^8.20.0"
  }
}
